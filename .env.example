# Your Locko API key (lk_ for service keys, lko_ for org keys)
LOCKO_API_KEY=lk_your_key_here

# Override the API base URL (e.g. for staging). Defaults to https://api-locko.barelyacompany.com
LOCKO_BASE_URL=https://api-locko.barelyacompany.com

# Service slug — required when using an org key (lko_ prefix)
# LOCKO_SERVICE_SLUG=my-service

# Set to "1" or "true" to enable debug logging
# LOCKO_DEBUG=1
