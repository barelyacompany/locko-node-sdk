{
  "name": "@barelyacompany/locko-node-sdk",
  "version": "1.1.0",
  "description": "Node.js SDK for Locko — secrets and config management",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "locko",
    "secrets",
    "config",
    "environment"
  ],
  "author": "tylerdgenius",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.0.0",
    "dotenv": "^17.4.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^2.0.0"
  }
}
